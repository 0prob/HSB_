# =========================
# Logging
# =========================
# Examples:
#   RUST_LOG=info
#   RUST_LOG=arbitrage_engine=info,arbitrage_engine::engine::arb=debug
RUST_LOG=info

# =========================
# Envio / HyperSync auth (optional)
# =========================
# If you have an Envio API token, set it. If not, leave blank.
ENVIO_API_TOKEN=

# =========================
# HyperSync ingestion window
# =========================
# Starting block for HyperSync queries (per chain runtime uses config/<chain>.toml for chain_id)
# For Polygon, ~60,000,000 is a reasonable “recent-ish” start.
HYPERSYNC_FROM_BLOCK=60000000

# Number of blocks per batch window when streaming
HYPERSYNC_WINDOW_BLOCKS=50000

# =========================
# Snapshot validation (HyperRPC / rpc_url in config/*.toml)
# =========================
# How many candidate routes to snapshot-check per cycle (2-hop)
SNAPSHOT_TOPK=50

# Concurrency for snapshot getReserves() calls (2-hop)
SNAPSHOT_CONCURRENCY=8

# How many candidate triangles to snapshot-check per cycle
SNAPSHOT_TOPK_TRI=50

# Concurrency for triangle snapshot checks
SNAPSHOT_CONCURRENCY_TRI=8

# =========================
# Liquidity / price-impact gating
# =========================
# Require reserve_in >= amount_in * MIN_RESERVE_IN_MULT on every hop.
# Higher = safer / fewer false positives. 50 is a good default.
MIN_RESERVE_IN_MULT=50

# =========================
# Universe filtering (chain-scoped)
# =========================
# These env vars are optional. If unset, the bot uses built-in defaults per chain.
#
# Format:
#   UNIVERSE_ALLOWED_TOKENS_<CHAINNAME_UPPER>=comma-separated 0x addresses
#   UNIVERSE_DENIED_TOKENS_<CHAINNAME_UPPER>=comma-separated 0x addresses
#   UNIVERSE_BASE_TOKENS_<CHAINNAME_UPPER>=comma-separated 0x addresses
#   UNIVERSE_REQUIRE_BASE_TOKEN_<CHAINNAME_UPPER>=true|false
#   UNIVERSE_ALLOWED_DEX_<CHAINNAME_UPPER>=comma-separated substrings matched against PairMeta.dex
#   UNIVERSE_MAX_POOLS_<CHAINNAME_UPPER>=integer

# ---- Polygon example (tight universe: stables + WMATIC/WETH only) ----
UNIVERSE_ALLOWED_TOKENS_POLYGON=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174,0xC2132D05D31c914a87C6611C10748AEb04B58e8F,0x8f3Cf7ad23Cd3CaDbD9735AFf958023239c6A063,0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270,0x7ceB23fD6bC0adD59E62ac25578270cFf1b9f619

# If true, every pool must include at least one base token (base tokens default to common stables + WMATIC/WETH)
UNIVERSE_REQUIRE_BASE_TOKEN_POLYGON=true

# Allow only these DEX tags (substrings)
UNIVERSE_ALLOWED_DEX_POLYGON=quickswap_v2,quickswap_algebra

# Registry cap (per chain)
UNIVERSE_MAX_POOLS_POLYGON=5000

# Denylist always wins
UNIVERSE_DENIED_TOKENS_POLYGON=0x000000000000000000000000000000000000dead
